# Goal
string mode           # "DRIVE", "STRAFE", or "TURN"
float64 target_value  # Distance in ticks (DRIVE/STRAFE) or Angle in degrees (TURN)
float64 max_speed     # Maximum motor power (0-255)
---
# Result
bool success          # True if target was reached successfully
---
# Feedback
float64 current_error # Current error from the target (ticks or degrees)